outputs/*
!outputs/.gitkeep
!outputs/create-pain-slide/
outputs/create-pain-slide/*
!outputs/create-pain-slide/.gitkeep
!outputs/generate-dossier/
outputs/generate-dossier/*
!outputs/generate-dossier/.gitkeep

# dossier-feedback outputs — phase-1 testing artefacts.
# Folder skeleton is tracked via .gitkeep; per-account markdown and routine
# state files stay local to each maintainer until the consumer side lands.
dossier-feedback/*
!dossier-feedback/.gitkeep

# Raw knowledge staging — source files stay local to each maintainer's machine.
# Master git tracks only the per-group INDEX.md (as the ingest history) and
# the folder skeleton. Notions, transcripts, clippings, Teams chats, and
# deep-research outputs are private provenance and must never be committed.
raw/*/notions/**
raw/*/transcripts/**
raw/*/clippings/**
raw/*/teams-chats/**
raw/*/deep-research/**
# Loose top-level raw files at raw/<slug>/*.md — PMMs drop sources here
# for kb-update's auto-batch path. Stay local to each maintainer; INDEX.md
# is explicitly preserved below.
raw/*/*.md
!raw/**/.gitkeep
!raw/*/INDEX.md

# Python
__pycache__/
*.pyc

# Skill-local node_modules (e.g. webinar-promo-card/scripts/node_modules) —
# installed on demand per machine, never committed.
skills/*/scripts/node_modules/
.claude/skills/*/scripts/node_modules/

# Campaign output (cards, slides, headshots, exports) is user-generated
# artifact, not skill source. Keep the folder + .gitkeep but nothing inside.
campaigns/*
!campaigns/.gitkeep

# kb-update / kb-integrate — machine-specific cached paths + Notion IDs.
# Auto-generated by resolve_mcp_path.py on first run; never commit.
.kb-local.json

# Claude Code local settings (per-machine; holds GEMINI_API_KEY and other
# secrets). Never commit — keep credentials off git history.
.claude/settings.local.json

# macOS Finder metadata
.DS_Store

# Local planning / review-tracking notes — kept on each maintainer's machine,
# never committed. Add new top-level planning docs to this list.
/REVIEW-PHASES.md
/POST-MIGRATION-FOLLOWUPS.md
/RESTRUCTURE-PLAN.md

# local MCP config (contains secrets)
.mcp.json
